# Copy this file to `.env` and fill in your Alchemy RPC URLs.
# Get them at https://dashboard.alchemy.com/  (free tier is fine).

# Required if any governor in governors.txt is on Ethereum mainnet.
# Also used for ENS resolution.
# Format: https://eth-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
RPC_URL=

# Required if any governor in governors.txt is on Base.
# Format: https://base-mainnet.g.alchemy.com/v2/<YOUR_API_KEY>
RPC_URL_BASE=
